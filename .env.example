# PostgreSQL connection string (Railway, Supabase, local…)
DATABASE_URL=postgres://user:password@localhost:5432/svutt

# Admin credentials (single admin user, no user management)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# Session secret for cookie signing. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Public base URL (used for QR codes in admin UI)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
